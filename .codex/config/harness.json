{
  "schemaVersion": 1,
  "phase": "preclean",
  "baseBranch": "main",
  "runtimeRoot": ".codex.local",
  "worktreeRoot": ".worktrees",
  "controlCheckout": {
    "path": ".",
    "purpose": "공유 문서, 정책, 하네스, 환경 설정 전용",
    "appCodeWritesAllowed": false
  },
  "teams": {
    "claude": {
      "worktreePath": ".worktrees/claude",
      "handoffTemplate": ".codex/templates/HANDOFF_TEMPLATE.md"
    },
    "codex": {
      "worktreePath": ".worktrees/codex",
      "handoffTemplate": ".codex/templates/HANDOFF_TEMPLATE.md"
    }
  },
  "branchTypes": [
    "feature",
    "fix",
    "docs",
    "chore",
    "refactor",
    "test",
    "spike"
  ],
  "phasePolicies": {
    "preclean": {
      "description": "문서, backlog 정제, 하네스, CI/환경 설정, 저장소 정리 전용",
      "allowedBranchTypes": [
        "docs",
        "chore",
        "spike"
      ],
      "forbiddenGlobs": [
        "**/*.cs",
        "**/*.csproj",
        "**/*.sln",
        "**/*.xaml",
        "src/**",
        "tests/**"
      ]
    },
    "implementation": {
      "description": "명시적 phase 승인 이후 기능 구현 단계",
      "allowedBranchTypes": [
        "feature",
        "fix",
        "docs",
        "chore",
        "refactor",
        "test",
        "spike"
      ],
      "forbiddenGlobs": []
    }
  }
}
